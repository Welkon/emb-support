{
  "name": "pmb180b",
  "family": "padauk-pmb180",
  "sample": false,
  "description": "Concrete PMB180B tool profile for Timer16, Timer2 PWM, LPWMG, LVDC, charger, and comparator calculations.",
  "supported_tools": [
    "timer-calc",
    "pwm-calc",
    "lpwmg-calc",
    "lvdc-threshold",
    "charger-config",
    "comparator-threshold"
  ],
  "source_refs": [
    "mcu/padauk-pmb180b",
    "mcu/padauk-pmb180b-registers"
  ],
  "component_refs": [],
  "bindings": {
    "timer-calc": {
      "algorithm": "padauk-timer16",
      "params": {
        "chip": "pmb180b",
        "peripheral": "timer16",
        "mode_macro": "T16M",
        "default_clock_source": "sysclk",
        "default_edge": "rising",
        "prescalers": [
          1,
          4,
          16,
          64
        ],
        "interrupt_bits": [
          8,
          9,
          10,
          11,
          12,
          13,
          14,
          15
        ],
        "clock_source_aliases": {
          "clk": "sysclk",
          "system": "sysclk",
          "pa0f": "pa0",
          "pa4f": "pa4"
        },
        "clock_sources": {
          "sysclk": { "macro": "SYSCLK" },
          "ihrc": { "macro": "IHRC" },
          "ilrc": { "macro": "ILRC" },
          "pa0": { "macro": "PA0" },
          "pa4": { "macro": "PA4" }
        }
      }
    },
    "pwm-calc": {
      "algorithm": "padauk-tm2-pwm",
      "params": {
        "chip": "pmb180b",
        "peripheral": "tm2",
        "mode_macro": "TM2C",
        "scale_macro": "TM2S",
        "counter_register": "TM2CT",
        "period_register": "TM2B",
        "default_clock_source": "sysclk",
        "default_output_pin": "pa3",
        "default_resolution": "auto",
        "prescalers": [
          1,
          4,
          16,
          64
        ],
        "divider_min": 1,
        "divider_max": 32,
        "resolutions": [
          8,
          7,
          6
        ],
        "clock_source_aliases": {
          "clk": "sysclk",
          "system": "sysclk",
          "comp": "comparator",
          "co": "comparator",
          "eosc": "nilrc",
          "pa0": "pa0r",
          "pa4": "pa4r"
        },
        "clock_sources": {
          "sysclk": { "macro": "SYSCLK" },
          "ihrc": { "macro": "IHRC" },
          "ilrc": { "macro": "ILRC" },
          "nilrc": { "macro": "NILRC" },
          "comparator": { "macro": "COMPARATOR" },
          "pa0r": { "macro": "PA0_R" },
          "pa0f": { "macro": "PA0_F" },
          "pa4r": { "macro": "PA4_R" },
          "pa4f": { "macro": "PA4_F" }
        },
        "output_pins": {
          "pa3": { "macro": "PA3" },
          "pa4": { "macro": "PA4" }
        }
      }
    },
    "lpwmg-calc": {
      "algorithm": "padauk-lpwmg",
      "params": {
        "chip": "pmb180b",
        "peripheral": "lpwmg",
        "clock_control_register": "LPWMGCLK",
        "upper_limit_high_register": "LPWMGCUBH",
        "upper_limit_low_register": "LPWMGCUBL",
        "default_clock_source": "sysclk",
        "default_channel": "lpwmg0",
        "prescalers": [
          1,
          2,
          4,
          8,
          16,
          32,
          64,
          128
        ],
        "max_counter": 1023,
        "clock_source_aliases": {
          "clk": "sysclk",
          "system": "sysclk",
          "ihrcx2": "ihrc2x",
          "ihrc2x": "ihrc2x",
          "2xihrc": "ihrc2x"
        },
        "clock_sources": {
          "sysclk": { "macro": "SYSCLK" },
          "ihrc": { "macro": "IHRC" },
          "ihrc2x": { "macro": "IHRC" }
        },
        "channel_aliases": {
          "0": "lpwmg0",
          "1": "lpwmg1",
          "2": "lpwmg2",
          "lpg0": "lpwmg0",
          "lpg1": "lpwmg1",
          "lpg2": "lpwmg2"
        },
        "channels": {
          "lpwmg0": {
            "control_macro": "LPWMG0C",
            "output_select_macro": "LPWMG0",
            "duty_high_register": "LPWMG0DTH",
            "duty_low_register": "LPWMG0DTL",
            "default_output_pin": "pa0",
            "output_pins": {
              "pa0": { "macro": "PA0" },
              "pa1": { "macro": "PA1" },
              "pa5": { "macro": "PA5" }
            }
          },
          "lpwmg1": {
            "control_macro": "LPWMG1C",
            "output_select_macro": "LPWMG1",
            "duty_high_register": "LPWMG1DTH",
            "duty_low_register": "LPWMG1DTL",
            "default_output_pin": "pa4",
            "output_pins": {
              "pa4": { "macro": "PA4" },
              "pa6": { "macro": "PA6" }
            }
          },
          "lpwmg2": {
            "control_macro": "LPWMG2C",
            "output_select_macro": "LPWMG2",
            "duty_high_register": "LPWMG2DTH",
            "duty_low_register": "LPWMG2DTL",
            "default_output_pin": "pa3",
            "output_pins": {
              "pa3": { "macro": "PA3" },
              "pa5": { "macro": "PA5" }
            }
          }
        }
      }
    },
    "lvdc-threshold": {
      "algorithm": "padauk-lvdc",
      "params": {
        "chip": "pmb180b",
        "peripheral": "lvdc",
        "register_name": "LVDC",
        "threshold_field": "[7:2]",
        "shift_bits": 2,
        "min_voltage": 1.85,
        "step_voltage": 0.05,
        "level_count": 64,
        "charging_voltage_bias": 0.15,
        "status_when_set": "VBAT is below the configured LVD threshold.",
        "status_when_clear": "VBAT is above the configured LVD threshold.",
        "status_when_set_charging": "Internal detection reads ~0.15V high during charging; actual VBAT is typically ~0.15V below the configured threshold.",
        "status_when_clear_charging": "Internal detection reads ~0.15V high during charging; actual VBAT is typically ~0.15V below the comparison result.",
        "interrupt_supported": false,
        "wakeup_supported": false
      }
    },
    "charger-config": {
      "algorithm": "padauk-charger",
      "params": {
        "chip": "pmb180b",
        "peripheral": "charger",
        "control_macro": "CHG_CTRL",
        "status_register": "CHG_TEMP",
        "current_steps_ma": [
          50,
          100,
          200,
          250,
          300,
          350,
          400,
          500
        ],
        "legacy_full_hold_seconds": 1,
        "capacity_rule_mah_per_hour": 500,
        "auto_start_note": "PMB180(B) charger module operates on hardware defaults after power-up; MCU init is not strictly required.",
        "status_bits": {
          "charge_indicator": {
            "register": "CHG_CTRL",
            "bit": 0,
            "when_set": "Candidate for termination/stop state. Do not use alone for full-charge detection; combine with V400_FG and duration.",
            "when_clear": "Charging started or in progress."
          },
          "charge_complete_indicator": {
            "register": "CHG_TEMP",
            "bit": 1,
            "when_set": "PMB180B measured: charging. Padauk documentation often reverses this.",
            "when_clear": "PMB180B measured: charge complete. Padauk documentation often reverses this."
          },
          "vcc_greater_than_vbat": {
            "register": "CHG_TEMP",
            "bit": 4,
            "when_set": "VCC is above VBAT.",
            "when_clear": "VCC is below or not above VBAT."
          },
          "vcc_normal": {
            "register": "CHG_TEMP",
            "bit": 3,
            "when_set": "VCC voltage normal.",
            "when_clear": "VCC voltage too low; charger is off."
          },
          "v400_flag": {
            "register": "V400_FG",
            "bit": 0,
            "when_set": "Battery voltage has exceeded the 4V threshold.",
            "when_clear": "Battery voltage has not yet exceeded the 4V threshold."
          }
        }
      }
    },
    "comparator-threshold": {
      "algorithm": "padauk-comparator",
      "params": {
        "chip": "pmb180b",
        "peripheral": "gpc",
        "control_macro": "GPCC",
        "select_macro": "GPCS",
        "default_positive_source": "internal_ref",
        "default_negative_source": "pa3",
        "bandgap_voltage": 1.2,
        "charging_voltage_bias": 0.15,
        "positive_sources": {
          "internal_ref": { "macro": "P_R" },
          "pa4": { "macro": "P_PA4" }
        },
        "negative_sources": {
          "pa3": { "macro": "N_PA3" },
          "pa4": { "macro": "N_PA4" },
          "bandgap": { "macro": "BANDGAP" },
          "internal_ref": { "macro": "N_R" },
          "pa6": { "macro": "N_PA6" },
          "pa7": { "macro": "N_PA7" }
        },
        "internal_reference_cases": [
          { "bits": "00", "base": 8, "denominator": 32 },
          { "bits": "01", "base": 0, "denominator": 24 },
          { "bits": "10", "base": 8, "denominator": 40 },
          { "bits": "11", "base": 0, "denominator": 32 }
        ]
      }
    },
    "adc-scale": {
      "algorithm": "unsupported",
      "reason": "PMB180(B) datasheet does not indicate ADC resources."
    }
  },
  "notes": [
    "Timer16 prescaler supports /1, /4, /16, /64; interrupt bits BIT8~BIT15.",
    "Timer2 PWM supports 8/7/6-bit resolution; output pins PA3 or PA4.",
    "Timer2 clock sources: SYSCLK, IHRC, ILRC, NILRC, comparator output, and PA0/PA4 edges.",
    "LPWMG0/1/2 share LPWMGCLK, LPWMGCUBH, LPWMGCUBL; lpwmg-calc is exposed.",
    "LVDC exposed as lvdc-threshold; internal detection reads ~0.15V above actual battery voltage during charging.",
    "Charger module exposed as charger-config; 5V input detection requires CHG_TEMP.4 && CHG_TEMP.3.",
    "PMB180 (rev 0) full-charge detection requires CHG_CTRL.0, V400_FG, and duration. PMB180B additionally references CHG_TEMP.1 (high=charging, low=full).",
    "GPC comparator uses the same 4-group internal reference formulas as PMS150G; PMB180(B) also has comparator interrupt/wakeup capability.",
    "LPWMG uses shared upper-limit counter and half-step duty model; duty numerator: DB + DB0*0.5 + 0.5.",
    "PMB180B does not provide ADC."
  ]
}
