    "comparator-threshold": {
      "algorithm": "scmcu-comparator",
      "params": {
        "chip": "sc8f072",
        "peripheral": "comp",
        "bandgap_voltage": 1.2,
        "default_positive_source": "vr",
        "default_negative_source": "cmp0n",
        "positive_sources": {
          "vr": {
            "cmp_ps": 0
          },
          "cmp_plus": {
            "cmp_ps": 1
          }
        },
        "positive_source_aliases": {},
        "negative_sources": {
          "cmp0n": {
            "cmp_ns": "000"
          },
          "cmp1n": {
            "cmp_ns": "001"
          },
          "cmp2n": {
            "cmp_ns": "010"
          },
          "cmp3n": {
            "cmp_ns": "011"
          },
          "vr": {
            "cmp_ns": "100"
          },
          "bandgap": {
            "cmp_ns": "101"
          }
        },
        "negative_source_aliases": {
          "pa1": "cmp0n",
          "cmp_in": "cmp0n"
        },
        "internal_reference_cases": [
          {
            "rbias_h": 0,
            "rbias_l": 0,
            "offset_numerator": 1,
            "offset_denominator": 4,
            "step_base": 1,
            "step_denominator": 32,
            "formula": "VDD/4 + (n+1)/32 * VDD"
          },
          {
            "rbias_h": 0,
            "rbias_l": 1,
            "offset_numerator": 0,
            "offset_denominator": 1,
            "step_base": 1,
            "step_denominator": 24,
            "formula": "(n+1)/24 * VDD"
          },
          {
            "rbias_h": 1,
            "rbias_l": 0,
            "offset_numerator": 1,
            "offset_denominator": 5,
            "step_base": 1,
            "step_denominator": 40,
            "formula": "VDD/5 + (n+1)/40 * VDD"
          },
          {
            "rbias_h": 1,
            "rbias_l": 1,
            "offset_numerator": 0,
            "offset_denominator": 1,
            "step_base": 1,
            "step_denominator": 32,
            "formula": "(n+1)/32 * VDD"
          }
        ]
      }
    },
