# Reference only. Keep real machine-local values out of the repository.
# Set one of these in your shell profile, CI variables, or user environment.

# Preferred when you know the exact compiler path.
XC8_EXE=/absolute/path/to/xc8.exe

# Preferred when you only know the SCMCU IDE install root.
# The script will use <SCMCU_IDE_ROOT>/data/bin/xc8.exe automatically.
SCMCU_IDE_ROOT=/absolute/path/to/SCMCU_IDE

# The build script also probes common install roots automatically:
# - SCMCU_IDE*
# - WorkToolsAndLib/SCMCU_IDE*
# - Tools/SCMCU_IDE*
# - Program Files/SCMCU_IDE*
# - Program Files (x86)/SCMCU_IDE*

# Common shell examples:
# PowerShell:
#   $env:XC8_EXE = 'D:\path\to\xc8.exe'
# Bash / WSL:
#   export XC8_EXE=/mnt/d/path/to/xc8.exe
